{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": false,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "´ćĺ ",
      "default": "´äî "
    },
    "persistent-workspaces": {
      "*": 3
    }
  },
  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 14,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "Alacritty",
      "kitty"
    ],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },
  // Clock
  "clock": {
    "format": "{:%H:%M %a}",
    "on-click": "gnome-calendar",
    "timezone": "",
    "tooltip": false
  },
  "memory": {
    "interval": 1,
    "format": "{icon} {percentage}%",
    "format-icons": {
      "default": "ţ┐ů "
    },
    "on-click": "gnome-system-monitor"
  },
  "cpu": {
    "interval": 1,
    "format": "{icon} {usage}%",
    "format-icons": {
      "default": "´ĺ╝ "
    },
    "tooltip": false,
    "on-click": "gnome-system-monitor"
  },
  "network": {
    "interval": 1,
    "format-wifi": "´çź  ´ÇÖ {bandwidthDownBytes}  ´éô {bandwidthUpBytes}",
    "format-ethernet": "ˇ░łÇ  ´ÇÖ {bandwidthDownBytes}  ´ÇÖ {bandwidthUpBytes}",
    "format-disconnected": "ˇ░ľ¬ Disconnected",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr} {bandwidthDownBits}bps\uf019/{bandwidthUpBits}bps\uf093",
    "on-click": "~/dotfiles/global/scripts/network.sh",
    "on-click-right": "~/dotfiles/global/scripts/nm-applet.sh",
    "format-icons": {
      "default": [
        "\uf0c1",
        "\uf0c2",
        "\uf0c3"
      ]
    },
    "fixed-size": 150
  },
  // Battery
  "battery": {
    "interval": 1,
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "ˇ░éä {capacity}%",
    "format-plugged": "´çŽ {capacity}%",
    "format-alt": "{icon} {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": [
      "ˇ░ü║",
      "ˇ░ü╗",
      "ˇ░üż",
      "ˇ░éü",
      "ˇ░ü╣"
    ]
  },
  // Power Profiles Daemon
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "´ćů ",
      "performance": "´âž ",
      "balanced": "´ëÄ  ",
      "power-saver": "´üČ "
    }
  },
  "tray": {
    "spacing": 10,
    "icon-size": 14,
  },
  // Pulseaudio
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "´Őö {volume}%",
    "format-bluetooth-muted": "´Őö ´ĹŽ  {format_source}",
    "format-muted": "´ĹŽ  {format_source}",
    "format-source": "{volume}% ",
    "format-source-muted": "´ä▒ ",
    "format-icons": {
      "muted": "´ĹŽ ",
      "headphone": "´Çą ",
      "hands-free": "´ľÉ ",
      "headset": "´ľÉ ",
      "phone": "´éĽ ",
      "portable": "´éĽ ",
      "car": "´ć╣ ",
      "default": [
        "´ÇŽ ",
        "´Çž ",
        "´ÇĘ "
      ]
    },
    "on-click": "pavucontrol"
  },
  // Bluetooth
  "bluetooth": {
    "format": "´Őô {status}",
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },
  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ţÄŹ",
      "ţĆö",
      "ţĆô",
      "ţĆĺ",
      "ţĆĹ",
      "ţĆÉ",
      "ţĆĆ",
      "ţĆÄ",
      "ţĆŹ",
      "ţĆî",
      "ţĆő",
      "ţĆŐ",
      "ţĆë",
      "ţĆł",
      "ţÄŤ"
    ],
    "scroll-step": 1
  }
}
